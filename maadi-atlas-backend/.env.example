# Google Maps Platform key — needs Geocoding API and Distance Matrix API enabled.
# Leave blank for local dev; the pipeline falls back to Nominatim for geocoding
# and a free-flow traffic estimate (score defaults to 70) so the app still runs.
GOOGLE_MAPS_KEY=

# Port the Fastify server listens on.
PORT=3001

# Comma-separated list of origins allowed to hit /api/*.
# Example: http://localhost:5173,https://maadi-atlas.pages.dev
FRONTEND_ORIGIN=http://localhost:5173

# Path to the SQLite file. Relative to cwd; use an absolute path in production
# so the mount point (Render disk / Fly volume) is stable across deploys.
DB_PATH=./data/atlas.db

# Shared secret for POST /api/listings/refresh (Phase 3). Any non-empty value
# required; requests without a matching X-Admin-Secret header are rejected.
ADMIN_SECRET=
